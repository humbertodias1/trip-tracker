@model PackingItem
@{
    ViewData["Title"] = "Edit Packing Item";
}

<h1 class="h3 mb-3">Edit Packing Item</h1>
<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="TripId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label asp-for="Quantity" class="form-label"></label>
                    <input asp-for="Quantity" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Category" class="form-label"></label>
                    <input asp-for="Category" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="AssignedTo" class="form-label"></label>
                    <input asp-for="AssignedTo" class="form-control" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="IsPacked" class="form-check-input" />
                        <label asp-for="IsPacked" class="form-check-label"></label>
                    </div>
                </div>
                <div class="col-md-10">
                    <label asp-for="Notes" class="form-label"></label>
                    <input asp-for="Notes" class="form-control" />
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-primary">Save</button>
                <a asp-action="Dashboard" asp-route-id="@Model.TripId" asp-route-tab="packing" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

