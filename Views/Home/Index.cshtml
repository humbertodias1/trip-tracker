@{
    ViewData["Title"] = "Welcome";
}

<div class="p-5 mb-4 bg-white border rounded-3">
    <div class="container-fluid py-3">
        <h1 class="display-6 fw-bold">Plan every trip detail in one place</h1>
        <p class="col-md-8 fs-5 text-muted">
            TripTracker helps you manage itinerary, expenses, packing, and document links for each trip.
        </p>
        <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Register">Create Account</a>
        <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Login">Login</a>
    </div>
</div>

